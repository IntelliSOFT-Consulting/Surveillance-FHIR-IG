    // ── Deaths Due to Malaria ────────────────────────────────────────────────
    diseasesPage.item as summ where linkId = 'deaths-due-to-malaria-summary' then {
      diseasesPage.item as u5c where linkId = 'deaths-due-to-malaria-cases-under-5' then {
