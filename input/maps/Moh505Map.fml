              summ -> e.request as req, req.method = 'POST', req.url = 'Observation' "reqCreate";
            } "afpObs";
            } "o5d";
          } "u5d";
        } "o5c";
      } "u5c";
    } "afp";

    // ── Anthrax ──────────────────────────────────────────────────────────────
    diseasesPage.item as summ where linkId = 'anthrax-summary' then {
      diseasesPage.item as u5c where linkId = 'anthrax-cases-under-5' then {
        diseasesPage.item as o5c where linkId = 'anthrax-cases-over-5' then {
          diseasesPage.item as u5d where linkId = 'anthrax-deaths-under-5' then {
            diseasesPage.item as o5d where linkId = 'anthrax-deaths-over-5' then {
              summ.answer first as ans where valueCoding.code = 'yes' -> bundle.entry as e then {
              summ -> e.resource = create('Observation') as obs then CreateMoh505DiseaseObs(summ, u5c, o5c, u5d, o5d, obs) "obsCreate";
              summ -> e.request as req, req.method = 'POST', req.url = 'Observation' "reqCreate";
