    } "suspectedMalaria";

    // ── VHF ──────────────────────────────────────────────────────────────────
    diseasesPage.item as summ where linkId = 'vhf-summary' then {
      diseasesPage.item as u5c where linkId = 'vhf-cases-under-5' then {
